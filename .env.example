# Copy to `.env` (next to docker-compose.yml) and fill in before `docker compose up`.

# REQUIRED. The JWT signing key. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Anyone who knows this key can forge admin sessions — never commit a real one.
SECRET_KEY=

# Database password (used by both the db and backend services).
POSTGRES_PASSWORD=consulthub

# Public base URL of the app (used in emailed reset/invite/activation links).
FRONTEND_BASE_URL=http://localhost:8080

# Seed a demo tenant + users (admin@consulthub.local / consulthub) on first
# start. For LOCAL DEMOS ONLY — the seeded accounts have a known password.
# Leave false for any deployment reachable by others.
SEED_ON_START=false

# Dev only. When true, console email/SMS transports log full message bodies
# (so reset/invite links are clickable). MUST be false in production — the
# bodies contain single-use account tokens and patient PII.
DEBUG=false

# Optional email delivery (else links are logged, redacted unless DEBUG=true).
SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Optional SMS/WhatsApp delivery via Twilio (else messages log to console).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
# TWILIO_WHATSAPP_FROM=
