# Copy to .env and adjust for your environment.

# Dev default is SQLite. For production use PostgreSQL, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/consulthub
DATABASE_URL=sqlite:///./consulthub.db

# Comma-separated list of allowed CORS origins (frontend dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth — MUST be overridden in production.
# SECRET_KEY=change-me
# Base URL used in emailed password-reset / invite links.
FRONTEND_BASE_URL=http://localhost:5173

# Escalation engine. Disable to turn off the background scheduler; the interval
# controls how often overdue consults are re-scanned (seconds).
ESCALATION_ENABLED=true
ESCALATION_INTERVAL_SECONDS=60

# Email. Leave SMTP_HOST unset to log emails to the console (dev default).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=secret
# SMTP_FROM=ConsultHUB <no-reply@yourhospital.org>
# SMTP_TLS=true

# Attachment storage (local disk for dev; swap for S3-compatible in prod).
STORAGE_DIR=./uploads
MAX_UPLOAD_MB=15
